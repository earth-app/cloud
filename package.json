{
  "private": true,
  "name": "@earth-app/cloud",
  "version": "1.0.0",
  "description": "The Automaton behind The Earth App",
  "scripts": {
    "test": "bunx vitest run",
    "test:coverage": "bunx vitest run --coverage",
    "dev": "bunx wrangler dev --port 9898 --test-scheduled",
    "deploy": "bunx wrangler deploy --minify",
    "prettier": "bunx prettier --write .",
    "prettier:check": "bunx prettier --check .",
    "prepare": "husky install"
  },
  "dependencies": {
    "@cloudflare/workerd-darwin-arm64": "^1.20260417.1",
    "@earth-app/moho": "^1.0.2",
    "@earth-app/ocean": "^1.0.4",
    "@types/bun": "^1.3.12",
    "@types/pako": "^2.0.4",
    "exifreader": "^4.38.1",
    "hono": "^4.12.14",
    "music-metadata": "^11.12.3",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@vitest/coverage-istanbul": "4.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  },
  "lint-staged": {
    "*.{js,ts,json,yml,md}": "prettier --write"
  }
}
