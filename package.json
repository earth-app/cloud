{
  "private": true,
  "name": "@earth-app/cloud",
  "version": "1.0.0",
  "description": "The Automaton behind The Earth App",
  "scripts": {
    "test": "bunx vitest run",
    "test:coverage": "bunx vitest run --coverage",
    "test:report": "bunx vitest --reporter=junit --outputFile=test-report.junit.xml",
    "dev": "bunx wrangler dev --port 9898 --test-scheduled",
    "deploy": "bunx wrangler deploy --minify",
    "prettier": "bunx prettier --write .",
    "prettier:check": "bunx prettier --check .",
    "prepare": "husky install"
  },
  "dependencies": {
    "@cloudflare/workerd-darwin-arm64": "^1.20260703.1",
    "@earth-app/moho": "^1.0.2",
    "@earth-app/ocean": "^1.1.0",
    "@types/bun": "^1.3.14",
    "@types/pako": "^2.0.4",
    "exifreader": "^4.41.0",
    "hono": "^4.12.27",
    "music-metadata": "^11.13.0",
    "pako": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@vitest/coverage-istanbul": "4.1.9",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  },
  "lint-staged": {
    "*.{js,ts,json,yml,md}": "prettier --write"
  }
}
